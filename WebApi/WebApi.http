@WebApi_HostAddress = http://localhost:5009

GET {{WebApi_HostAddress}}/weatherforecast/
Accept: application/json

###

# Test Tenant Creation
POST {{WebApi_HostAddress}}/api/tenants/add
Content-Type: application/json
tenant: root

{
  "identifier": "test-tenant-2",
  "name": "Test Tenant 2",
  "isActive": true,
  "connectionString": "Server=DESKTOP-CEEFFEU\\SQLEXPRESS; Database=TestTenant2Db; Trusted_Connection = true; Encrypt=False; MultipleActiveResultSets=True;",
  "email": "admin@testtenant2.com",
  "firstName": "Test",
  "lastName": "Admin",
  "validUpTo": "2025-12-31T23:59:59Z"
}

