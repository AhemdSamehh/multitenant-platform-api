# Test Duplicate Tenant Creation (Should Fail)
POST {{WebApi_HostAddress}}/api/tenants/add
Content-Type: application/json
tenant: root

{
  "identifier": "test-tenant-2",
  "name": "Duplicate Tenant",
  "isActive": true,
  "connectionString": "Server=DESKTOP-CEEFFEU\\SQLEXPRESS; Database=DuplicateDb; Trusted_Connection = true; Encrypt=False; MultipleActiveResultSets=True;",
  "email": "duplicate@test.com",
  "firstName": "Duplicate",
  "lastName": "User",
  "validUpTo": "2025-12-31T23:59:59Z"
}

